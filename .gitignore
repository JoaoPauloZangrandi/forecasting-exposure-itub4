# =============================================================================
# Dados brutos da CVM — grandes (~4,2 GB), NÃO versionar.
# Ficam fora do repo e são referenciados por DATA_DIR em R/00_config.R.
# Para usar outra pasta, defina CVM_DATA_DIR. Ver data/raw/README.md.
# =============================================================================
data/raw/*.csv
data/raw/**/*.csv

# Cache binário dos extracts (grande; reconstruível). O painel .csv É versionado.
data/processed/_cache_*.rds

# Lista de arestas da CDA (grande ~57 MB; regenerável por R/10_build_cda_edges.R).
data/processed/cda_edges.csv

# Extracts por fundo-mês (regeneráveis por R/_prep_fund_extracts.R).
data/processed/itub4_fundmonth.csv
data/processed/pl_fundmonth.csv

# Painel de TODAS as ações (grande; regenerável por R/12_all_stocks.R).
data/processed/painel_all_stocks.csv

